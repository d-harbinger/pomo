venv/
venv-*/
__pycache__/
*.pyc
.env
*.egg-info/
dist/
build/
# generated app icon — gen_icon.py is the single source of truth; install.sh
# and the app regenerate pomo.png on demand, so the bitmap is a build artifact,
# not a tracked source (it changes byte-for-byte on every regen otherwise).
pomo.png
# privacy-guard: per-clone patterns file (gitignored; see .privacy-patterns.example)
.privacy-patterns
# privacy-guard: privacy-related script log output (audit, host gates, etc.)
.gsd-logs/
# privacy-guard: track .claude/settings.json (project hook config), ignore the rest
.claude/*
!.claude/settings.json
# privacy-guard: per-clone trusted-SSID allowlist for lan-guard (gitignored — SSIDs are network identifiers)
.lan-allow
# privacy-guard: local script log output (audit, host gates, build/test logs)
.dev-logs/
