#!/usr/bin/env bash
# Pre-commit privacy guard. Blocks the commit if staged changes contain
# patterns that look like device or host identifiers leaking into the repo.
#
# Setup (one-time per machine, per clone):
#   git config core.hooksPath scripts/hooks
#
# Bypass for an individual commit (use sparingly, and only if you've
# manually confirmed the match is a false positive):
#   git commit --no-verify
#
# Extending the patterns:
#   • Project-wide patterns lived here, in the BUILTIN_PATTERNS array
#     below. Add entries that make sense for every developer.
#   • Per-developer / per-machine patterns go in a gitignored
#     `.privacy-patterns` file at the repo root, one regex per line
#     (lines starting with `#` are comments, blank lines ignored).
#     Use this for your own home-dir path, internal hostnames, device
#     serials specific to your hardware, etc.
#
# Why this exists: a Samsung Galaxy serial got committed into planning
# docs + commit messages across ~150 commits on 2026-05-14 because no
# automatic check existed. A git-filter-repo + force-push rewrote the
# public history, but the lesson is that we shouldn't rely on humans
# remembering. The hook makes the rule mechanical.

set -e

RED=$'\e[31m'
YELLOW=$'\e[33m'
RESET=$'\e[0m'

PG_LIB="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)/lib/patterns.sh"
if [ ! -f "$PG_LIB" ]; then
  printf '%s\n' "${RED}privacy-guard: pattern library missing at $PG_LIB${RESET}" >&2
  printf '%s\n' "${YELLOW}install incomplete — re-run install.sh --force${RESET}" >&2
  exit 1
fi
# shellcheck source=../lib/patterns.sh
. "$PG_LIB"

# Detection patterns: single-sourced from lib/patterns.sh (scope commit|both).
mapfile -t BUILTIN_PATTERNS < <(pg_grep_patterns)

repo_root="$(git rev-parse --show-toplevel)"
extra_patterns_file="$repo_root/.privacy-patterns"

# Load user-supplied patterns (per-clone, gitignored).
EXTRA_PATTERNS=()
if [ -f "$extra_patterns_file" ]; then
  while IFS= read -r line; do
    case "$line" in
      ''|'#'*) continue ;;
      *) EXTRA_PATTERNS+=("$line") ;;
    esac
  done < "$extra_patterns_file"
fi

ALL_PATTERNS=("${BUILTIN_PATTERNS[@]}" "${EXTRA_PATTERNS[@]}")

# Self-match excludes — the scanner sources plus lib/patterns.sh (which now
# holds the regex definitions) and the templates/ tree — are single-sourced
# from lib/patterns.sh as PG_EXCLUDE_PATHS. Code review, not the hook, is the
# control for changes to those files.
EXCLUDE_PATHS=( "${PG_EXCLUDE_PATHS[@]}" )

# Synthetic data declared in .privacy-allow (committed, one literal VALUE per
# line). This file USED to list PATH globs that were excluded from the scan —
# but "trust this whole directory" let a real device serial hide inside an
# allow-listed tests/ folder and reach GitHub. So we allow by VALUE, never by
# path: scan everything, then suppress a finding ONLY when the matched text is
# exactly a declared synthetic value. An unknown identifier in any path —
# fixtures included — still fires. Trust a string, never a location.
allow_file="$repo_root/.privacy-allow"
ALLOW_VALUES=()
if [ -f "$allow_file" ]; then
  while IFS= read -r raw; do
    line="${raw%%#*}"                          # strip inline comment
    line="${line#"${line%%[![:space:]]*}"}"    # ltrim
    line="${line%"${line##*[![:space:]]}"}"    # rtrim
    [ -z "$line" ] && continue
    ALLOW_VALUES+=("$line")
  done < "$allow_file"
fi

# Suppress a finding only if the matched text EXACTLY equals a declared value.
# Exact, not substring: declaring a demo "AKIA…" key must not silently allow a
# different real key that merely contains the same prefix.
_is_allowed() {
  local v="$1" a
  for a in "${ALLOW_VALUES[@]}"; do [ "$v" = "$a" ] && return 0; done
  return 1
}

# Keep every added line (`^+`), then strip exactly one leading '+' so the diff
# prefix is gone but content that legitimately starts with '+' is preserved,
# and ^-anchored patterns (e.g. the ADB device-serial) match real content. The
# old `^\+[^+]` filter silently dropped added lines whose content began with
# '+' (rendered `++…` in the diff), letting a leak on such a line slip past.
staged_added="$(git diff --cached --unified=0 -- "${EXCLUDE_PATHS[@]}" \
  | grep -E '^\+' | sed 's/^+//' || true)"

if [ -z "$staged_added" ]; then
  exit 0
fi

violations=""
for pat in "${ALL_PATTERNS[@]}"; do
  # Case-SENSITIVE (no -i). The patterns encode their own case (AKIA, IMEI,
  # Samsung, PEM headers); -i made the device-serial rule over-match ordinary
  # prose — e.g. "Google dependency" matched (Google)\s+[A-Z][A-Z0-9]{6,}
  # because -i let "dependency" satisfy the uppercase serial class. Dropping -i
  # kills that false alarm and aligns the hook with audit-privacy.sh, which
  # already greps case-sensitive. Patterns needing case-tolerance bake it in.
  # grep -o so we test the MATCHED VALUE against .privacy-allow, not the line.
  while IFS= read -r m; do
    [ -z "$m" ] && continue
    _is_allowed "$m" && continue
    violations="${violations}${RED}Pattern matched:${RESET} ${YELLOW}${pat}${RESET}  ->  ${m}
"
  done < <(printf '%s\n' "$staged_added" | grep -Eo -- "$pat" | sort -u || true)
done

# --- Tightened bare-serial check (commit-stage) ---------------------------
# A serial with no brand word in front of it (mid-line in a log or doc) slips
# vendor_serial, and the broad shape [A-Z0-9]{10,14} alone would also flag git
# SHAs and uppercase words. So pull CANDIDATES, then keep only the ones that
# look like a real device serial: has a digit AND a non-hex letter [G-Z]. Git
# SHAs are all-hex (no [G-Z]); uppercase words have no digit. Both fall out, so
# bare serials get caught with few false alarms. (generic_serial stays probe-
# only — this token-level filter is what makes a serial check safe at commit.)
serial_hits=""
while IFS= read -r tok; do
  [ -z "$tok" ] && continue
  [[ "$tok" == *[0-9]* ]] || continue      # must contain a digit
  [[ "$tok" == *[G-Z]* ]] || continue      # must contain a non-hex letter
  _is_allowed "$tok" && continue           # declared synthetic value? skip
  serial_hits="${serial_hits}  ${tok}
"
done < <(printf '%s\n' "$staged_added" | grep -Eo '\b[A-Z0-9]{10,14}\b' | sort -u)
if [ -n "$serial_hits" ]; then
  violations="${violations}${RED}Pattern matched:${RESET} ${YELLOW}bare device serial (10-14 uppercase, digit + non-hex letter)${RESET}
$serial_hits
"
fi

if [ -n "$violations" ]; then
  printf '%s\n' "${RED}--- pre-commit privacy guard: staged content matches sensitive patterns ---${RESET}"
  printf '%s\n' "$violations"
  printf '%s\n' "${YELLOW}If a match is a false positive, you can bypass once with:${RESET}"
  printf '%s\n' "  git commit --no-verify"
  printf '%s\n' "${YELLOW}If a match is real, edit the staged file to remove the identifier, then re-stage and re-commit.${RESET}"
  exit 1
fi

# ----------------------------------------------------------------------------
# Layer 2: gitleaks. The bash patterns above cover workspace-specific things
# gitleaks doesn't know about (device serials, /home/<user>/ paths, RFC1918
# IPs). gitleaks adds ~150 cloud-provider patterns + entropy detection on top.
#
# Required, not optional. Per the workspace policy, we want the broader net.
# If gitleaks is missing, fail clearly rather than silently letting commits
# through with weaker coverage.
# ----------------------------------------------------------------------------
if ! command -v gitleaks >/dev/null 2>&1; then
  printf '%s\n' "${RED}--- pre-commit privacy guard: gitleaks not installed ---${RESET}"
  printf '%s\n' "${YELLOW}gitleaks is required by this repo's privacy guard. Install it once:${RESET}"
  printf '%s\n' ""
  printf '%s\n' "  CachyOS / Arch (recommended):  paru -S gitleaks"
  printf '%s\n' "                                 sudo pacman -S gitleaks  # if you don't use paru"
  printf '%s\n' "  Mint / Debian / Ubuntu:        download the latest gitleaks_*_linux_x64.tar.gz from"
  printf '%s\n' "                                 https://github.com/gitleaks/gitleaks/releases and"
  printf '%s\n' "                                 install the 'gitleaks' binary on PATH."
  printf '%s\n' "  go-installed:                  go install github.com/gitleaks/gitleaks/v8@latest"
  printf '%s\n' ""
  printf '%s\n' "${YELLOW}Bypass once for an unrelated emergency:${RESET}  git commit --no-verify"
  exit 1
fi

# `protect --staged` scans the staged index, not the working tree. --redact
# replaces the secret value in the report with [REDACTED] so the secret itself
# is never written to terminal scrollback. --no-banner suppresses the ASCII
# logo on every run.
if ! gitleaks protect --staged --redact --no-banner --config="$repo_root/.gitleaks.toml" 2>&1; then
  printf '%s\n' ""
  printf '%s\n' "${RED}--- pre-commit privacy guard: gitleaks found one or more secrets ---${RESET}"
  printf '%s\n' "${YELLOW}If a match is a real secret:${RESET}  remove it from the staged file, re-stage, re-commit."
  printf '%s\n' "${YELLOW}If a match is a false positive:${RESET} add it to the [allowlist] in .gitleaks.toml"
  printf '%s\n' "${YELLOW}                                ${RESET}(see comments in that file for the regex/path format)."
  printf '%s\n' "${YELLOW}Bypass once for an unrelated emergency:${RESET}  git commit --no-verify"
  exit 1
fi

exit 0
